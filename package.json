{
  "name": "bioworld-decision-os",
  "private": true,
  "packageManager": "pnpm@10.34.5",
  "scripts": {
    "contracts:check": "corepack pnpm contracts:check-generated && corepack pnpm --filter @bioworld/contracts check && corepack pnpm --filter @bioworld/contracts test",
    "contracts:check-generated": "node tools/check-generated-contracts.mjs",
    "contracts:generate": "buf generate",
    "migrations:tools:test": "node --test tools/postgres-migrations.test.mjs",
    "migrations:postgres:test": "node tools/postgres-migrations.mjs",
    "desktop:dev": "corepack pnpm --filter @bioworld/desktop dev",
    "desktop:build": "corepack pnpm --filter @bioworld/desktop build",
    "desktop:icons:check": "node tools/validate-tauri-icons.mjs",
    "desktop:tools:test": "node --test tools/native-desktop.test.mjs tools/tauri-icons.test.mjs",
    "desktop:native:preflight": "node tools/native-desktop.mjs preflight",
    "desktop:native:check": "node tools/native-desktop.mjs check",
    "desktop:native:test": "node tools/native-desktop.mjs test",
    "desktop:native:clippy": "node tools/native-desktop.mjs clippy",
    "desktop:native:build": "node tools/native-desktop.mjs build"
  },
  "devDependencies": {
    "@bufbuild/buf": "1.72.0",
    "@bufbuild/protoc-gen-es": "2.12.1"
  }
}
