{
  "name": "bioworld-decision-os",
  "private": true,
  "packageManager": "pnpm@10.34.5",
  "scripts": {
    "contracts:check": "corepack pnpm contracts:check-generated && corepack pnpm --filter @bioworld/contracts check && corepack pnpm --filter @bioworld/contracts test",
    "contracts:check-generated": "node tools/check-generated-contracts.mjs",
    "contracts:generate": "buf generate",
    "desktop:dev": "corepack pnpm --filter @bioworld/desktop dev",
    "desktop:build": "corepack pnpm --filter @bioworld/desktop build"
  },
  "devDependencies": {
    "@bufbuild/buf": "1.72.0",
    "@bufbuild/protoc-gen-es": "2.12.1"
  }
}
